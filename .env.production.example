# Production build for GoDaddy (setuai.com)
# Vite loads this as .env.production during `npm run build`.

# Contact form — leave empty to use same-origin /api/contact (PHP)
VITE_CONTACT_API_URL=

# -----------------------------------------------------------------------------
# SETU APIs on GoDaddy static hosting (recommended)
# -----------------------------------------------------------------------------
# Leave VITE_API_URL empty and use relative bases (/auth, /dashboard, …).
# public/.htaccess rewrites those paths to public/api/staging-proxy.php, which
# forwards to https://api.setuai.com (same idea as Vite's local proxy).
#
# Do NOT point the browser straight at the API host unless ALLOWED_ORIGINS
# includes https://setuai.com / https://www.setuai.com AND helmet CORP allows
# cross-origin. Today the API blocks that, so the PHP proxy is required.
VITE_API_URL=

# Optional per-service overrides (defaults = relative paths above via api.js)
# VITE_AUTH_BASE=/auth
# VITE_DASHBOARD_BASE=/dashboard
# VITE_BOOKTEST_BASE=/booktest
# VITE_MED_BASE=/telemedicine/api/v1
# VITE_ASSETS_BASE=/assets
# VITE_CLOUDFRONT_BASE=https://d10pnqyli54qno.cloudfront.net

# Optional: only if API CORS/CORP is fixed for the marketing site
# VITE_API_URL=https://api.setuai.com
