# Production build — leave empty to use same-origin /api/contact (PHP on GoDaddy)
VITE_CONTACT_API_URL=

# Absolute API host required when Vite proxy is not available (e.g. static hosting)
# VITE_API_URL=https://staging.setuai.com
# Or set each base explicitly:
# VITE_AUTH_BASE=https://staging.setuai.com/auth
# VITE_DASHBOARD_BASE=https://staging.setuai.com/dashboard

