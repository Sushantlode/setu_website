# Copy to .env and fill in values (never commit .env)
CONTACT_API_PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CONTACT_TO_EMAIL=support@setuai.com
SMTP_HOST=setuai.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no_reply@setuai.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM="Setu <no_reply@setuai.com>"
SEND_USER_CONFIRMATION=false
SITE_NAME=SETU
CONTACT_DAILY_LIMIT=3

# SETU app APIs (dev: relative paths proxied to api.setuai.com via vite.config.js)
# Production on GoDaddy: keep relative paths — .htaccess + api/staging-proxy.php
# forward /auth, /dashboard, etc. to https://api.setuai.com (avoids CORS).
# Direct absolute host only if API CORS/CORP allow https://setuai.com:
# VITE_API_URL=https://api.setuai.com
VITE_API_URL=
VITE_AUTH_BASE=/auth
VITE_API_BASE=
VITE_DASHBOARD_BASE=/dashboard
VITE_SOS_BASE=/sos/api/v1
VITE_BOOKTEST_BASE=/booktest
VITE_ABHA_BASE=/abha
VITE_DRUG_BASE=/drug/api/v1
VITE_MED_BASE=/telemedicine/api/v1
VITE_GENERIC_BASE=/generic/api
VITE_MENTAL_BASE=/mental/api
VITE_AGRI_BASE=/agri
VITE_SCHEMES_BASE=/schemes
VITE_FITNESS_BASE=/fitness
VITE_REPORTS_BASE=/reports/api/v1
VITE_PREVENTIVE_BASE=/preventive-health
# Static marketing/app images live in public/assets/. Vite proxies /assets/api to production storage.
VITE_ASSETS_BASE=/assets
# Storage API host (report icons, dashboard art). Staging storage often 500s — use production.
# VITE_ASSETS_API_HOST=https://api.setuai.com
VITE_CLOUDFRONT_BASE=https://d10pnqyli54qno.cloudfront.net

# Razorpay key id (public client key — same as RN RAZORPAY_KEY_ID)
# VITE_RAZORPAY_KEY_ID=rzp_live_...
